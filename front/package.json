{
  "name": "hongkai-helper",
  "private": true,
  "version": "1.0.0",
  "description": "Hongkai Helper Tool",
  "main": "electron/main.js",
  "scripts": {
    "dev": "..\\node\\node-v20.11.1-win-x64\\node.exe node_modules\\vite\\bin\\vite.js",
    "build": "..\\node\\node-v20.11.1-win-x64\\node.exe node_modules\\vite\\bin\\vite.js build",
    "preview": "..\\node\\node-v20.11.1-win-x64\\node.exe node_modules\\vite\\bin\\vite.js preview",
    "electron:dev": "set ELECTRON_START_URL=http://localhost:5173 && ..\\node\\node-v20.11.1-win-x64\\node.exe node_modules\\electron\\cli.js .",
    "electron:build": "npm run build && ..\\node\\node-v20.11.1-win-x64\\node.exe node_modules\\electron-builder\\cli.js"
  },
  "dependencies": {
    "vue": "^3.5.24"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.4",
    "electron": "^27.0.0",
    "electron-builder": "^24.12.0",
    "vite": "^5.2.0"
  },
  "build": {
    "appId": "com.hongkai.helper",
    "productName": "Hongkai Helper",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/main.js",
      "dist/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "portable": {
      "artifactName": "HongkaiHelper-${version}-portable.exe"
    }
  }
}
